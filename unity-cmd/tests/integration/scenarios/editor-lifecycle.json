{
  "name": "editor-lifecycle",
  "description": "Editor edit tools, one Play cycle (editor_play + screenshot), stop; play/stop stress lives in editor-reliability-stress",
  "steps": [
    {
      "name": "00_force_stop_before_suite",
      "command": "stop",
      "timeoutMs": 20000,
      "expect": { "ok": true }
    },
    { "name": "00b_wait_after_forced_stop", "sleepMs": 1500 },
    {
      "name": "01_ping_editor",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 40
    },
    {
      "name": "02_state_edit",
      "command": "state",
      "expect": {
        "ok": true,
        "data": { "is_playing": false, "play_mode": "edit" },
        "dataHas": ["connector_state", "commands_ready", "is_compiling", "connector_build", "ready_for_tools"]
      }
    },
    {
      "name": "03_list_catalog_edit",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["compile", "console", "echo", "exec", "ping", "play", "profiler", "screenshot", "state"],
        "forbidden": ["echo.runtime"],
        "forbiddenScopes": ["runtime"]
      }
    },
    {
      "name": "04_echo_editor",
      "command": "echo",
      "expect": { "data": { "channel": "editor" } }
    },
    {
      "name": "05_console",
      "command": "console",
      "args": ["--type", "error,warning", "--lines", "5"],
      "expect": { "ok": true, "dataHas": ["count", "entries"] }
    },
    {
      "name": "06_profiler_status_edit",
      "command": "profiler",
      "args": ["--action", "status"],
      "expect": { "ok": true, "dataHas": ["enabled", "frame_count"] }
    },
    {
      "name": "07_exec",
      "command": "exec",
      "args": ["--code", "return 1 + 1;"],
      "timeoutMs": 20000,
      "expect": { "ok": true, "dataHas": ["result"] }
    },
    {
      "name": "08_enter_play",
      "command": "play",
      "timeoutMs": 20000,
      "expect": { "ok": true }
    },
    {
      "name": "09_wait_editor_play_endpoint",
      "waitProfile": "editor-play",
      "timeoutMs": 20000
    },
    {
      "name": "10_echo_runtime",
      "hostKind": "editor_play",
      "command": "echo",
      "expect": { "data": { "channel": "runtime" } }
    },
    {
      "name": "11_ping_editor_play",
      "hostKind": "editor_play",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 40
    },
    {
      "name": "12_reject_compile_on_editor_play",
      "hostKind": "editor_play",
      "command": "compile",
      "expectFailure": true
    },
    {
      "name": "13_list_catalog_editor_play",
      "hostKind": "editor_play",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["echo", "ping"],
        "forbidden": ["compile", "console", "echo.editor", "exec", "play", "profiler", "screenshot", "state"],
        "forbiddenScopes": ["editor"]
      }
    },
    {
      "name": "14_list_catalog_editor_during_play",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": ["compile", "console", "ping", "play", "profiler", "screenshot", "state"],
        "forbidden": ["echo.runtime"],
        "forbiddenScopes": ["runtime"]
      }
    },
    {
      "name": "15_state_during_play",
      "command": "state",
      "expect": { "ok": true, "data": { "is_playing": true, "play_mode": "playing" } }
    },
    {
      "name": "16_profiler_status_during_play",
      "command": "profiler",
      "args": ["--action", "status"],
      "expect": { "ok": true, "dataHas": ["enabled", "frame_count", "is_playing"] }
    },
    {
      "name": "17_screenshot_game_via_editor_host",
      "hostKind": "editor",
      "command": "screenshot",
      "args": [
        "--view",
        "game",
        "--output_path",
        "${UNITY_CMD_CACHE_DIR}/integration-editor-lifecycle-play.png",
        "--width",
        "640",
        "--height",
        "360"
      ],
      "expect": { "ok": true, "dataHas": ["path", "width", "height"] }
    },
    {
      "name": "18_assert_screenshot_file",
      "assertFile": {
        "path": "${UNITY_CMD_CACHE_DIR}/integration-editor-lifecycle-play.png",
        "minBytes": 400
      }
    },
    {
      "name": "19_exit_play",
      "command": "stop",
      "timeoutMs": 20000,
      "expect": { "ok": true }
    },
    { "name": "20_wait_editor_after_stop", "sleepMs": 2000 },
    {
      "name": "21_state_after_play",
      "command": "state",
      "expect": { "ok": true, "data": { "is_playing": false } }
    },
    {
      "name": "22_echo_editor_after_play",
      "command": "echo",
      "expect": { "data": { "channel": "editor" } }
    },
    {
      "name": "23_ping_final",
      "command": "ping",
      "expect": {
        "ok": true,
        "data": { "listener_running": true, "commands_ready": true, "play_mode": "edit" }
      }
    }
  ]
}
