{
  "name": "full-lifecycle",
  "steps": [
    {
      "name": "ping",
      "command": "ping",
      "expect": { "ok": true },
      "expectConnectorBuild": 5
    },
    {
      "name": "list_catalog",
      "command": "list",
      "expect": { "ok": true },
      "expectCatalog": {
        "commands": [
          "compile",
          "editor.console",
          "editor.play",
          "ping"
        ]
      }
    },
    {
      "name": "console_errors",
      "command": "console",
      "args": ["--type", "error,warning", "--lines", "5"],
      "expect": { "ok": true, "dataHas": ["count", "entries"] }
    },
    {
      "name": "logs_alias",
      "command": "logs",
      "args": ["--lines", "1"],
      "expect": { "ok": true, "dataHas": ["count"] }
    },
    {
      "name": "enter_play",
      "command": "editor.play",
      "expectJob": "succeeded",
      "timeoutMs": 60000
    },
    {
      "name": "assert_playing",
      "assertManifest": { "is_playing": true }
    },
    {
      "name": "runtime_echo",
      "command": "echo.runtime",
      "expect": { "data": { "channel": "runtime" } }
    },
    {
      "name": "exit_play",
      "command": "editor.stop",
      "expectJob": "succeeded",
      "timeoutMs": 60000
    },
    {
      "name": "editor_echo",
      "command": "echo.editor",
      "expect": { "data": { "channel": "editor" } }
    },
    {
      "name": "connector_state",
      "command": "connector.state",
      "expect": { "ok": true, "dataHas": ["is_playing", "is_compiling"] }
    },
    {
      "name": "compile",
      "command": "compile",
      "expectJob": "succeeded",
      "timeoutMs": 120000,
      "allowConnectionRetry": true
    }
  ]
}
